# LFAS local environment example
ASPNETCORE_ENVIRONMENT=Development

# PostgreSQL container defaults for docker-compose.yml.
POSTGRES_USER=lfas
POSTGRES_PASSWORD=lfas_dev_password_change_me
POSTGRES_DB=lfas
POSTGRES_PORT=5432

# pgAdmin local-only defaults for docker-compose.yml.
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin_change_me

# Application local configuration.
LOCAL_STORAGE_ROOT=./storage
OLLAMA_BASE_URL=http://localhost:11434

# Optional local connection string override.
# Keep real passwords in user secrets or a local .env file, never in appsettings.
ConnectionStrings__lfasdb=Host=localhost;Port=5432;Database=lfas;Username=lfas;Password=lfas_dev_password_change_me
